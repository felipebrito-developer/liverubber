{
  "_version": "registry/v1",
  "project": {
    "name": "LiveRubber",
    "description": "Neuro-inclusive React Native fitness application.",
    "root": ".",
    "packageManager": "bun",
    "testRunner": "bun:test",
    "linter": "bun biome check --write ."
  },
  "workspaces": {
    "shared": {
      "path": "packages/shared/",
      "specialist": "agent-shared-type-architect"
    },
    "backend": {
      "path": "apps/service/",
      "specialist": "agent-be-architect"
    },
    "mobile": {
      "path": "apps/mobile/",
      "type": "mobile",
      "specialist": "agent-mobile-architect",
      "config": {
        "framework": "react-native",
        "version": "0.78",
        "rules": [
          "./.agents/rules/mobile-rules.md",
          "./.agents/workflows/mobile-component-reuse.md"
        ]
      }
    },
    "ai": {
      "path": "apps/ai-bridge/",
      "specialist": "agent-ai-bridge-specialist"
    },
    "docs": {
      "path": "docs/",
      "specialist": "agent-doc-updater"
    }
  },
  "permissions": {
    "allow": [
      "./.agents/bin/bun install",
      "./.agents/bin/bun run dev --host 0.0.0.0",
      "./.agents/bin/bun run test",
      "./.agents/bin/bun biome",
      "./.agents/bin/bun x tsc",
      "ls",
      "grep",
      "cat",
      "mkdir",
      "cp",
      "touch",
      "mv",
      "find",
      "./.agents/bin/biome check --write",
      "./.agents/bin/turbo run build"
    ],
    "deny": [
      "rm -rf",
      "mv (outside project root)",
      "sudo",
      "curl"
    ],
    "agent-file-manager": {
      "allowedRoots": [".", ".agents/"],
      "lintCommand": "bun biome check --write ."
    },
    "agent-qa-specialist": {
      "writeAccess": ["**/*.spec.ts", "**/*.test.ts", "e2e/**", "__tests__/**", "test-plans/**"]
    },
    "agent-test-runner": {
      "functionalCommand": "bun test",
      "regressionCommand": "bun test --coverage"
    }
  },
  "env": {
    "BUN_BINARY": "./.agents/bin/bun",
    "BIOME_BINARY": "./.agents/bin/biome",
    "TURBO_BINARY": "./.agents/bin/turbo",
    "REMOTE_DEBUGGING_URL": "http://$WINDOWS_HOST:9222",
    "USE_LOOPBACK": false
  },
  "trusted_commands": [
    "./.agents/bin/bun install",
    "./.agents/bin/biome check",
    "./.agents/bin/turbo run dev"
  ]
}