{
	"name": "liverubber",
	"private": true,
	"packageManager": "bun@1.3.3",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo run dev --parallel",
		"build": "turbo run build",
		"type-check": "turbo run type-check",
		"lint": "turbo run lint",
		"setup:all": "turbo run setup",
		"clean:cache": "turbo run clean",
		"clean:all": "rm -rf node_modules && turbo run clean"
	},
	"devDependencies": {
		"turbo": "^2.6.1",
		"@biomejs/biome": "^2.3.7",
		"typescript": "^5.9.3"
	}
}
