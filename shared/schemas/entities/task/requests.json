{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "task/requests",
    "title": "Task Requests",
    "allOf": [
        {
            "$ref": "../../base/common-api.json#/definitions/APIRequest"
        }
    ],
    "definitions": {
        "CreateTaskRequest": {
            "type": "object",
            "properties": {
                "title": {
                    "type": "string",
                    "minLength": 1
                },
                "description": {
                    "type": "string"
                },
                "priority": {
                    "$ref": "./task.json#/properties/priority"
                },
                "dueDate": {
                    "$ref": "./task.json#/properties/dueDate"
                },
                "tags": {
                    "$ref": "./task.json#/properties/tags"
                }
            },
            "required": [
                "title",
                "priority"
            ]
        },
        "GetTaskListRequestInput": {
            "type": "object",
            "properties": {
                "title": {
                    "type": "string",
                    "minLength": 1
                },
                "description": {
                    "type": "string"
                },
                "priority": {
                    "$ref": "./task.json#/properties/priority"
                },
                "dueDate": {
                    "$ref": "./task.json#/properties/dueDate"
                },
                "tags": {
                    "$ref": "./task.json#/properties/tags"
                }
            }
        }
    }
}