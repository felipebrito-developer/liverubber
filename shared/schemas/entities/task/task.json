{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "task/taskDefinition",
    "title": "TaskDefinition",
    "type": "object",
    "allOf": [
        {
            "$ref": "../base/entity.json#/definitions/Entity"
        }
    ],
    "properties": {
        "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
        },
        "description": {
            "type": "string",
            "maxLength": 1000
        },
        "dueDate": {
            "type": "string",
            "format": "date-time"
        },
        "tags": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "default": []
        }
    },
    "required": [
        "title",
        "priority",
        "status"
    ],
    "additionalProperties": false
}