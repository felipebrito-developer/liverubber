{
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noImplicitAny": "error",
        "noUntypedPublicSignature": "warn"
      }
    }
  },
  "formatter": {
    "indentStyle": "space",
    "indentSize": 2,
    "lineWidth": 100
  }
}