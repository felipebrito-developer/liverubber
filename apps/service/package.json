{
	"name": "@liverubber/service",
	"private": true,
	"scripts": {
		"dev": "bun run --watch src/cmd/server.ts",
		"mcp": "bun run src/internal/mcp/server.ts",
		"build": "bun build ./src/cmd/server.ts --outdir dist --target node",
		"type-check": "tsc --noEmit",
		"setup": "bun install"
	},
	"dependencies": {
		"@liverubber/shared": "workspace:*",
		"@modelcontextprotocol/sdk": "^1.12.1",
		"cors": "^2.8.6",
		"express": "^5.2.1",
		"helmet": "^8.1.0",
		"morgan": "^1.10.1",
		"uuid": "^13.0.0",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@types/bun": "^1.0.0",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/morgan": "^1.9.10",
		"@types/uuid": "^11.0.0",
		"typescript": "^5.9.3"
	},
	"packageManager": "bun@1.3.3"
}
