{
	"compilerOptions": {
		"lib": ["ESNext"],
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"baseUrl": ".",
		"paths": {
			"@liverubber/shared": ["../../packages/shared/index.ts"],
			"@liverubber/shared/*": ["../../packages/shared/*"]
		}
	},
	"include": ["./src/**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
