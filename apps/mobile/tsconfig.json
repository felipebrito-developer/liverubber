{
	"extends": "./node_modules/@react-native/typescript-config/tsconfig.json",
	"compilerOptions": {
		"strict": true,
		"skipLibCheck": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"],
			"@liverubber/shared/*": ["../../packages/shared/*"]
		},
		"types": ["jest", "node"],
		"jsx": "react-native"
	},
	"include": ["src/**/*.ts", "src/**/*.tsx", "index.js"],
	"exclude": ["node_modules", ".android", ".ios"]
}
