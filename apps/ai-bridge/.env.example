# Gemini API key (required for cloud routing)
GEMINI_API_KEY=

# Ollama configuration (local LLM, must be running via CUDA WSL2)
# Default: http://localhost:11434/v1
OLLAMA_BASE_URL=http://localhost:11434/v1

# Model to use for local inference via Ollama
# Available: deepseek-r1:8b, llama3.2, mistral, etc.
OLLAMA_MODEL=deepseek-r1:8b

# Port for the ai-bridge HTTP server
AI_BRIDGE_PORT=3001
