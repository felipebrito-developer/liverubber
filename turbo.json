{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},
		"dev": {
			"dependsOn": ["^build"],
			"persistent": true,
			"cache": false
		},
		"type-check": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"lint": {
			"cache": false
		},
		"setup": {},
		"clean": {
			"cache": false
		},
		"start": {
			"cache": false,
			"persistent": true
		},
		"android": {
			"cache": false,
			"persistent": false
		},
		"android:build": {
			"cache": false,
			"persistent": false
		}
	}
}
