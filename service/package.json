{
  "name": "service",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "go mod download && go mod tidy",
    "build": "mkdir -p bin && go build -o bin/server ./cmd/server",
    "dev": "go run ./cmd/server",
    "test": "go test ./...",
    "test:verbose": "go test -v ./...",
    "test:cover": "go test -cover ./...",
    "clean": "go clean && rm -rf bin/",
    "lint": "golangci-lint run ./...",
    "fmt": "gofmt -w .",
    "vet": "go vet ./..."
  }
}